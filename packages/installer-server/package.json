{
  "name": "@tensorix/openclaw-installer-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclaw-installer": "dist/bin/installer.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "dev": "tsx watch src/bin/installer.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@fastify/static": "8.0.2",
    "execa": "9.5.1",
    "fastify": "5.1.0",
    "keytar": "7.9.0",
    "open": "10.1.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.13",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
